NODE_ENV = "development"
PORT = "3001"

SERVICE_NAME = "book-service"
APP_VERSION = "1.0.0"

OTEL_DIAG = ""
OTEL_SERVICE_NAME = "book-service"
OTEL_EXPORTER_OTLP_ENDPOINT = "http://localhost:4318"

PG_HOST = "localhost:5432"
PG_USER = "user"
PG_PASSWORD = "password"
PG_DATABASE = "book_db"
PG_CONNECTION_LIMIT = "10"

KAFKA_CLIENT_ID = "app"
KAFKA_BROKERS = "localhost:9092"
KAFKA_GROUP_ID = "book-service"

S3_ENDPOINT = "localhost"
S3_PORT = "9000"
S3_USE_SSL = "false"
S3_ACCESS_KEY = "minio"
S3_SECRET_KEY = "minio12345678"
S3_BUCKET = "book-files"
S3_REGION = "us-east-1"
S3_PUBLIC_BASE_URL = "http://localhost:9000"

SNOWFLAKE_DATA_CENTER_ID = "0"
SNOWFLAKE_WORKER_ID = "0"

# Prisma Studio only
DATABASE_URL = "postgresql://user:password@localhost:5432/book_db?pgbouncer=true&connection_limit=10"
DIRECT_URL = "postgresql://user:password@localhost:5432/book_db"
