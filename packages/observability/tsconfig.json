{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"skipLibCheck": true,
		"paths": {
			"@/*": ["./src/*"],
			"#env": ["./src/env/index.ts"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.js", "src/**/*.cjs", "src/**/*.mjs", "bin"],
	"exclude": ["node_modules"]
}
