# Internal HTTP port exposed by the container.
PORT=3004

# Use an ONNX-exported reranker for the local stack.
RERANK_MODEL=onnx-community/bge-reranker-v2-m3-ONNX
# Optional fallback model name. Leave empty to disable.
RERANK_FALLBACK_MODEL=
# Allowed values: onnx | torch | openvino
RERANK_BACKEND=onnx
# Allowed values:
# - cpu for the lightweight profile
# - cuda for the GPU profile
RERANK_DEVICE=cpu
RERANK_BATCH_SIZE=16
RERANK_MAX_LENGTH=256
RERANK_MAX_CANDIDATES=200
RERANK_TOP_K_DEFAULT=10
RERANK_QUERY_MAX_CHARS=256
RERANK_CANDIDATE_MAX_CHARS=1600
# Allowed values: true | false
RERANK_ALLOW_BACKEND_FALLBACK=true
# Allowed values: true | false
RERANK_LOCAL_FILES_ONLY=false
# Allowed values: true | false
# Set to true for models with custom Hugging Face code,
# for example jinaai/jina-reranker-v2-base-multilingual.
RERANK_TRUST_REMOTE_CODE=false
RERANK_TEMP_DIR=.cache/temp
