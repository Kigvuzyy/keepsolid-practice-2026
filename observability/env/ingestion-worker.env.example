# Allowed values: production | development | test
NODE_ENV=production
# Internal HTTP port exposed by the container.
PORT=3003

SERVICE_NAME=ingestion-worker
APP_VERSION=1.0.0

OTEL_SERVICE_NAME=ingestion-worker
OTEL_EXPORTER_OTLP_ENDPOINT=http://otelcol:4318

# Postgres connection settings.
PG_HOST=pg:5432
PG_USER=user
PG_PASSWORD=password
PG_DATABASE=worker_db
PG_CONNECTION_LIMIT=10

# Kafka client settings.
KAFKA_CLIENT_ID=ingestion-worker
KAFKA_BROKERS=kafka:9094
KAFKA_GROUP_ID=ingestion-worker

# Local MinIO connection settings.
S3_ENDPOINT=minio
S3_PORT=9000
# Allowed values: true | false
S3_USE_SSL=false
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345678
S3_BUCKET=book-files
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=http://localhost:9000

# Required for embeddings generation.
OPENAI_API_KEY=
# Common values:
# - 1536 for text-embedding-3-small
# - 3072 for text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=1536
VECTORIZATION_MIN_CHUNK_CHARS=50

# Qdrant connection settings.
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# Allowed values: true | false
QDRANT_HTTPS=false
QDRANT_API_KEY=super-secret-key
QDRANT_COLLECTION_BOOK_CHUNKS=book_chunks_v1

# Snowflake ID generator settings.
SNOWFLAKE_DATA_CENTER_ID=0
SNOWFLAKE_WORKER_ID=1
