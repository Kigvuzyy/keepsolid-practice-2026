# Allowed values: production | development | test
NODE_ENV=production
# Internal HTTP port exposed by the container.
PORT=3002

SERVICE_NAME=search-service
APP_VERSION=1.0.0

OTEL_SERVICE_NAME=search-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://otelcol:4318

# Postgres connection settings.
PG_HOST=pg:5432
PG_USER=user
PG_PASSWORD=password
PG_DATABASE=search_db
PG_CONNECTION_LIMIT=10

# Kafka client settings.
KAFKA_CLIENT_ID=search-service
KAFKA_BROKERS=kafka:9094
KAFKA_GROUP_ID=search-service

# Local MinIO connection settings.
S3_ENDPOINT=minio
S3_PORT=9000
# Allowed values: true | false
S3_USE_SSL=false
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345678
S3_BUCKET=book-files
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=http://localhost:9000

# Required for embeddings generation.
OPENAI_API_KEY=
# Common values:
# - 1536 for text-embedding-3-small
# - 3072 for text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=1536

# Qdrant connection settings.
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# Allowed values: true | false
QDRANT_HTTPS=false
QDRANT_API_KEY=super-secret-key
QDRANT_COLLECTION_BOOK_CHUNKS=book_chunks_v1

# Redis cache connection settings.
REDIS_HOST=redis
REDIS_PORT=6379

# Rerank service integration settings.
RERANK_SERVICE_URL=http://rerank-service-py:3004
RERANK_TIMEOUT_MS=5000
RERANK_DEFAULT_WINDOW=100
RERANK_MAX_CANDIDATES=100
SEARCH_RERANK_CACHE_WINDOW=100
SEARCH_RERANK_CACHE_TTL_SECONDS=86400

# Snowflake ID generator settings.
SNOWFLAKE_DATA_CENTER_ID=0
SNOWFLAKE_WORKER_ID=2
