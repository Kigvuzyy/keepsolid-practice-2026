COMPOSE_PROJECT_NAME=library_search

# Build profile for apps/rerank-service-py.
# Supported values:
# - cpu: lightweight image for local/dev runs
# - gpu: heavy image with GPU-capable ONNX stack
RERANK_COMPUTE_PROFILE=cpu

# Local Grafana admin password.
GF_ADMIN_PASSWORD=admin123

# Local MinIO root credentials.
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345678

# Buckets created by minio-init for local infrastructure.
MIMIR_BUCKET=mimir
MIMIR_RULER_BUCKET=mimir-ruler
MIMIR_AM_BUCKET=mimir-alertmanager
TEMPO_BUCKET=tempo
BOOKS_BUCKET=book-files
TEMP_BUCKET=tmp
